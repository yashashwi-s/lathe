\relax 
\@writefile{toc}{\contentsline {section}{\numberline {1}Date}{1}{}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {2}Time}{1}{}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.1}Default (en-fulltext)}{1}{}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.2}en-Fulltext}{1}{}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.3}en-FULLTEXT}{2}{}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.4}en-FullText}{2}{}\protected@file@percent }
\gdef \@abspage@last{2}
