\nomenclatureentry{a$a$@[{$a$}]\begingroup The number of angels per unit   area\nomunit{\per\square\meter}\nomeqref {1}|nompageref}{1}
\nomenclatureentry{a$N$@[{$N$}]\begingroup The number of angels per needle point\nomeqref {1}|nompageref}{1}
\nomenclatureentry{a$A$@[{$A$}]\begingroup The area of the needle   point\nomunit{\square\meter}\nomeqref {1}|nompageref}{1}
\nomenclatureentry{a$\sigma$@[{$\sigma$}]\begingroup The total mass of angels per unit   area\nomunit{\kilogram\per\square\meter}\nomeqref {1}|nompageref}{1}
\nomenclatureentry{a$m$@[{$m$}]\begingroup The mass of one angel\nomunit{\kilogram}\nomeqref {1}|nompageref}{1}
