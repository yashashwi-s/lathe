# Environment / secrets
.env
__pycache__/
*.pyc

# Bulky generated binaries in data & results (regenerable via the pipeline)
data/reference_pdfs/**/*.pdf
data/reference_pdfs/**/*.aux
data/reference_pdfs/**/*.log
data/reference_pdfs/**/*.nav
data/reference_pdfs/**/*.out
data/reference_pdfs/**/*.snm
data/reference_pdfs/**/*.toc
results/**/*.pdf
results/**/*.png
# harness runs: keep model .typ outputs, prompts, and score summaries;
# ignore renders, diagnostics, and bulky CLI transcripts/logs
harness/runs/**/*.pdf
harness/runs/**/*.png
harness/runs/**/*.jpg
harness/runs/**/feedback/
harness/runs/**/final_diagnostics*/
harness/runs/**/final_compile*.log
ai_api/**/*.pdf
ai_api/**/*.png
logs/*.log
# Keep report assets and built reports tracked:
# assets/**  and  reports/*.pdf  are intentionally NOT ignored.

# Mac
.DS_Store

